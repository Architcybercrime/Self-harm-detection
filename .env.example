# ── DEPLOYMENT CONFIGURATION ────────────────────────
# Copy this file to .env and fill in actual values for your deployment

# Environment (development or production)
ENVIRONMENT=production

# Server Configuration
PORT=5000
HOST=0.0.0.0

# ── AUTHENTICATION ──────────────────────────────────
# REQUIRED: Use a strong 32+ character key for production
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-here-minimum-32-characters

# ── DATABASE (Supabase) ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# ── FILE UPLOAD ─────────────────────────────────────
# Maximum file upload size in MB
MAX_UPLOAD_SIZE=500

# Temporary directory for video processing
TEMP_DIR=/tmp/safesignal

# ── SPEECH RECOGNITION ──────────────────────────────
# Default language for speech transcription (e.g., en-US, hi-IN, pa-IN)
DEFAULT_SPEECH_LANGUAGE=en-US

# ── LOGGING ─────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── SECURITY ────────────────────────────────────────
# CORS allowed origins (comma-separated for production)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── ML MODEL ────────────────────────────────────────
# Path to trained model (local or cloud storage)
MODEL_PATH=backend/model/model.pkl
TFIDF_PATH=backend/model/tfidf.pkl
