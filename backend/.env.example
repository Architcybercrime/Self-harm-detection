# ────────────────────────────────────────────────────────────
# Self Harm Detection API — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit your real .env file to version control.
# ────────────────────────────────────────────────────────────

# ── JWT ──────────────────────────────────────────────────────
# Long random string used to sign JWT tokens.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-long-random-secret-key

# ── SUPABASE ─────────────────────────────────────────────────
# From your Supabase project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Vercel URL here in production.
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── ALERTS ───────────────────────────────────────────────────
# SendGrid API key for email alerts (optional)
SENDGRID_API_KEY=SG.replace-with-your-sendgrid-key

# Sender email registered with SendGrid
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# Twilio credentials for SMS/WhatsApp alerts (optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── MFA ──────────────────────────────────────────────────────
# Issuer name shown in authenticator apps
MFA_ISSUER=SafeSignal

# ── OPTIONAL ─────────────────────────────────────────────────
# Set to 1 to suppress TensorFlow logs
TF_CPP_MIN_LOG_LEVEL=3
TF_ENABLE_ONEDNN_OPTS=0
