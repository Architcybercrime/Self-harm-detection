# ================================================
# Self Harm Detection API - Environment Variables
# ================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!

# ── Supabase ─────────────────────────────────────
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_or_service_role_key_here

# ── JWT ──────────────────────────────────────────
# Use a long random string: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_strong_jwt_secret_key_here

# ── CORS ─────────────────────────────────────────
# Comma-separated list of extra allowed origins (add your Vercel URL here)
# Example: ALLOWED_ORIGINS=https://safesignal.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=

# ── MFA ──────────────────────────────────────────
MFA_ISSUER=SafeSignal

# ── Google OAuth ─────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Streamlit ────────────────────────────────────
# URL of the FastAPI backend (used by Streamlit and Docker)
API_URL=http://127.0.0.1:8000

# ── Flask (legacy backup app only) ───────────────
FLASK_ENV=development
FLASK_DEBUG=True